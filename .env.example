# =============================================================================
# Orion monorepo — environment variables
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Loaded by:
#   - apps/web  → dotenv -e ../../.env (dev & build)
#   - apps/api  → dotenv -e ../../.env (dev & start)
#   - packages  → database, services, logger
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# Local Docker Postgres:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev

# Supabase: use transaction pooler (:6543) for API runtime, direct/session for migrate.
# Runtime (pooler):
# DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-....pooler.supabase.com:6543/postgres?sslmode=require
# Migrations (direct — from Supabase Dashboard → Database → Direct connection):
# DATABASE_URL_DIRECT=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres?sslmode=require

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
PORT=8000
BASE_URL=http://localhost:8000
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# JWT auth (required)
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
ACCESS_TOKEN_SECRET=replace-with-openssl-rand-base64-32-chars-min
REFRESH_TOKEN_SECRET=replace-with-another-openssl-rand-base64-32-chars
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=30d

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Browser tRPC endpoint (rebuild web after changing)
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc
# Server-side Next.js → API (OAuth proxy route)
API_INTERNAL_URL=http://localhost:8000
# SKIP_ENV_VALIDATION=true

# -----------------------------------------------------------------------------
# Google OAuth — sign-in
# https://console.cloud.google.com/apis/credentials
#
# Local (API-direct — recommended):
#   GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Add the same URI under "Authorized redirect URIs" in Google Console.
#
# Production (orion.* web + orionserver.* API):
#   GOOGLE_OAUTH_REDIRECT_URI=https://orionserver.arnabsamanta.in/auth/google/callback
#   CLIENT_URL=https://orion.arnabsamanta.in
#   CORS_ORIGIN=https://orion.arnabsamanta.in
#   NEXT_PUBLIC_API_URL=https://orionserver.arnabsamanta.in/trpc
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# -----------------------------------------------------------------------------
# OpenAI (required — Orion Intelligence)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# Pinecone RAG (optional — agent works without it; RAG skips if unset)
# Index dimension MUST match OPENAI_EMBEDDING_DIMENSIONS (e.g. 1536 or 1024)
# -----------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_INDEX=orion-rag
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=80

# -----------------------------------------------------------------------------
# Inngest — durable background jobs (RAG ingest on every user message)
# Local: set INNGEST_DEV=1 and run `pnpm --filter @repo/api inngest:dev`
# Dashboard: http://localhost:8288
# Production: keys from https://app.inngest.com
# -----------------------------------------------------------------------------
INNGEST_DEV=1
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Corsair — Gmail & Google Calendar
# Run once after migrate: pnpm --filter @repo/api corsair:setup
# -----------------------------------------------------------------------------
# Encryption key (min 32 chars): openssl rand -base64 32
CORSAIR_KEK=replace-with-corsair-kek-min-32-chars

# User-facing redirects after connect (can be web URLs)
CORSAIR_GMAIL_REDIRECT_URI=http://localhost:3000/dashboard/inbox
CORSAIR_CALENDAR_REDIRECT_URI=http://localhost:3000/dashboard/calendar

# API OAuth callback for Corsair connect flow — add to Google Console redirect URIs
CORSAIR_CONNECT_REDIRECT_URI=http://localhost:8000/connect/callback

# Public HTTPS base for webhooks (ngrok in dev, API domain in prod — no trailing slash)
CORSAIR_WEBHOOK_BASE=https://your-public-https-url.example.com

# Webhook query secret (min 16 chars) — must match Pub/Sub subscription URL ?token=
CORSAIR_WEBHOOK_SECRET=replace-with-random-secret-min-16-chars

# Gmail Pub/Sub topic — projects/YOUR_PROJECT/topics/YOUR_TOPIC
GMAIL_PUBSUB_TOPIC_ID=projects/your-gcp-project/topics/your-topic-name

# -----------------------------------------------------------------------------
# Logger (optional)
# -----------------------------------------------------------------------------
LOGGER_LEVEL=debug

# -----------------------------------------------------------------------------
# API docs (optional)
# -----------------------------------------------------------------------------
PUBLIC_OPENAPI_DOCS=true
# OPENAPI_DOCS_SECRET=replace-with-secret-min-8-chars

# -----------------------------------------------------------------------------
# Email / Brevo (optional — not wired yet)
# -----------------------------------------------------------------------------
# BREVO_API_KEY=
# EMAIL_PROVIDER=brevo
# EMAIL_FROM=Orion <your-verified-sender@email.com>
# EMAIL_SENDER_NAME=Orion
