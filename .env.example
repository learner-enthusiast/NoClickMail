# =============================================================================
# Orion monorepo — environment variables
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Loaded by:
#   - apps/web  → dotenv -e ../../.env (dev & build)
#   - apps/api  → reads process.env from root .env
#   - packages  → database, services, logger
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required — packages/database)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev

# -----------------------------------------------------------------------------
# API server (apps/api)
# -----------------------------------------------------------------------------
PORT=8000
BASE_URL=http://localhost:8000
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# API runtime mode: development | prod
# Used by apps/api and packages/services (NOT the same as Next.js NODE_ENV).
NODE_ENV=development

# -----------------------------------------------------------------------------
# JWT auth (required — apps/web build + packages/services)
# Generate secrets (min 32 chars):
#   openssl rand -base64 32
# -----------------------------------------------------------------------------
ACCESS_TOKEN_SECRET=replace-with-openssl-rand-base64-32-chars-min
REFRESH_TOKEN_SECRET=replace-with-another-openssl-rand-base64-32-chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# -----------------------------------------------------------------------------
# Frontend (apps/web)
# -----------------------------------------------------------------------------
# Public tRPC endpoint (browser)
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc

# Server-side calls from Next.js → API (OAuth callback route, etc.)
API_INTERNAL_URL=http://localhost:8000

# Skip env validation during Docker/CI builds (optional)
# SKIP_ENV_VALIDATION=true

# -----------------------------------------------------------------------------
# Google OAuth — sign-in (required for Google login)
# Create credentials: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_OAUTH_REDIRECT_URI exactly.
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api-auth/google/callback

# -----------------------------------------------------------------------------
# OpenAI (required — packages/services, agent/chat)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# Corsair — Gmail & Google Calendar integration
# -----------------------------------------------------------------------------
# Encryption key (min 32 chars): openssl rand -base64 32
CORSAIR_KEK=replace-with-corsair-kek-min-32-chars

# OAuth callback after connecting Gmail/Calendar (user-facing URLs)
CORSAIR_GMAIL_REDIRECT_URI=http://localhost:3000/api-connect/gmail/callback
CORSAIR_CALENDAR_REDIRECT_URI=http://localhost:3000/api-connect/calendar/callback

# API-side OAuth callback (Corsair plugin flow)
CORSAIR_CONNECT_REDIRECT_URI=http://localhost:8000/connect/callback

# Public HTTPS base URL for webhooks (use ngrok/cloudflare tunnel in dev)
# Example: https://your-subdomain.ngrok-free.dev
CORSAIR_WEBHOOK_BASE=https://your-public-https-url.example.com

# Optional — verify incoming webhook requests
# CORSAIR_WEBHOOK_SECRET=replace-with-random-secret-min-16-chars

# Gmail Pub/Sub topic for push notifications (Google Cloud)
# Example: projects/your-gcp-project/topics/your-topic-name
GMAIL_PUBSUB_TOPIC_ID=projects/your-gcp-project/topics/your-topic-name

# -----------------------------------------------------------------------------
# Logger (optional — packages/logger)
# -----------------------------------------------------------------------------
LOGGER_LEVEL=debug

# -----------------------------------------------------------------------------
# API docs (optional — apps/api)
# -----------------------------------------------------------------------------
PUBLIC_OPENAPI_DOCS=true
# OPENAPI_DOCS_SECRET=replace-with-secret-min-8-chars

# -----------------------------------------------------------------------------
# Email / Brevo (optional — not wired in code yet)
# -----------------------------------------------------------------------------
# BREVO_API_KEY=
# EMAIL_PROVIDER=brevo
# EMAIL_FROM=Orion <your-verified-sender@email.com>
# EMAIL_SENDER_NAME=Orion

# -----------------------------------------------------------------------------
# Demo / seed helpers (optional — not wired in code yet)
# -----------------------------------------------------------------------------
# DEMO_LOGIN_ENABLED=false
# DEMO_USER_EMAIL=demo@orion.dev
# DEMO_USER_PASSWORD=DemoPass123!
# SEED_USER_EMAIL=demo@orion.dev
# SEED_DEMO_PASSWORD=DemoPass123!